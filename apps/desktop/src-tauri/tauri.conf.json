{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenShaper",
  "version": "0.1.0",
  "identifier": "app.openshaper.desktop",
  "build": {
    "frontendDist": "../../web/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm --filter @openshaper/web dev",
    "beforeBuildCommand": "pnpm --filter @openshaper/web build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "url": "/app",
        "title": "OpenShaper",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
