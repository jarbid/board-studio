{
  "name": "openshaper",
  "version": "0.1.0",
  "private": true,
  "description": "OpenShaper — modern surfboard CAD/CAM (rebuild of BoardCAD-LE)",
  "license": "GPL-3.0-or-later",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev --filter=@openshaper/web",
    "dev:desktop": "turbo run dev --filter=@openshaper/desktop",
    "build": "turbo run build --filter=!@openshaper/desktop",
    "build:desktop": "turbo run build --filter=@openshaper/desktop",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\""
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
